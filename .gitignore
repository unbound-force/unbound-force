# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.tmp
.vscode/
.idea/

# Environment
.env*

# Go
*.exe
*.test
*.out
/unbound
/mutimind
vendor/
bin/

# GoReleaser build output
dist/

# Legacy tool directories (renamed to .uf/ in Spec 025)
.dewey/
.hive/
.unbound-force/
.muti-mind/
.mx-f/

# Tool workspaces under .uf/ — track config, ignore runtime data
# Orchestration runtime state
.uf/workflows/
.uf/artifacts/
# Dewey runtime (index, cache, database)
.uf/dewey/graph.db
.uf/dewey/graph.db-shm
.uf/dewey/graph.db-wal
.uf/dewey/*.lock
.uf/dewey/cache/
.uf/dewey/dewey.log
# Replicator runtime (database, logs)
.uf/replicator/*.db
.uf/replicator/*.db-shm
.uf/replicator/*.db-wal
.uf/replicator/*.lock
# Muti-Mind runtime artifacts (not backlog)
.uf/muti-mind/artifacts/
# Mx F runtime metrics data
.uf/mx-f/data/

# Unbound Force — managed by uf init
# Runtime data under .uf/ (databases, caches, locks, logs)
.uf/workflows/
.uf/artifacts/
.uf/dewey/graph.db
.uf/dewey/graph.db-shm
.uf/dewey/graph.db-wal
.uf/dewey/*.lock
.uf/dewey/cache/
.uf/dewey/dewey.log
.uf/replicator/*.db
.uf/replicator/*.db-shm
.uf/replicator/*.db-wal
.uf/replicator/*.lock
.uf/muti-mind/artifacts/
.uf/mx-f/data/
# Legacy tool directories (renamed to .uf/ in Spec 025)
.dewey/
.hive/
.unbound-force/
.muti-mind/
.mx-f/
.DS_Store

# Prevent stray tool directories in subdirectories
cmd/**/.opencode/
cmd/**/.uf/
cmd/**/.specify/
cmd/**/openspec/
internal/**/.opencode/
internal/**/.uf/
internal/**/.specify/
internal/**/openspec/

*.log
gateway.pid
unbound-force
